<% @meta_title = "Open Data - Awesome Lists" %>
<% @meta_description = "Download open data exports of awesome lists and projects." %>

<div class="container-md">
  <h2>Open Data</h2>
  <p class="lead">Download open data exports of awesome lists and projects indexed by <a href="/">Ecosyste.ms: Awesome</a>.</p>

  <div class="row">
    <div class="col-md-8">
      <div class="card mb-3">
        <div class="card-header">
          <h5 class="mb-0">Lists</h5>
        </div>
        <div class="card-body">
          <p>All awesome lists indexed by this service.</p>
          <a href="/api/v1/lists.json" class="btn btn-primary">Download Lists JSON</a>
        </div>
      </div>

      <div class="card mb-3">
        <div class="card-header">
          <h5 class="mb-0">Projects</h5>
        </div>
        <div class="card-body">
          <p>All open source projects referenced in awesome lists.</p>
          <a href="/api/v1/projects.json" class="btn btn-primary">Download Projects JSON</a>
        </div>
      </div>

      <div class="card mb-3">
        <div class="card-header">
          <h5 class="mb-0">Topics</h5>
        </div>
        <div class="card-body">
          <p>All topics associated with projects and lists.</p>
          <a href="/api/v1/topics.json" class="btn btn-primary">Download Topics JSON</a>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card mb-3">
        <div class="card-header">
          API Documentation
        </div>
        <div class="card-body">
          <p>Full API documentation is available at <a href="/docs">/docs</a>.</p>
        </div>
      </div>
    </div>
  </div>
</div>
